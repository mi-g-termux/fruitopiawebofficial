  "firestore": {
    "settings/site_settings": {
      "schema": "SiteSettings",
      "description": "Direct core site metadata node override"
    },
    "settings/payment_settings": {
      "schema": "PaymentSettings",
      "description": "Central cashier billing rules override"
    },
    "settings/admin_credentials": {
      "schema": "AdminCredentials",
      "description": "Salted master dashboard keys"
    },
    "settings/install_status": {
      "schema": "InstallStatus",
      "description": "Application environment bootstrap flag"
    },
    "categories/{categoryId}": {
      "schema": "Category",
      "description": "Filtering slots for dynamic juices catalog"
    },
    "products/{productId}": {
      "schema": "Product",
      "description": "Dynamic stock models of juices and smoothies"
    },
    "coupons/{couponId}": {
      "schema": "Coupon",
      "description": "Cash discount code records"
    },
    "reviews/{reviewId}": {
      "schema": "Review",
      "description": "Customer feedback and scores review logs"
    },
    "delivery_zones/{zoneId}": {
      "schema": "DeliveryZone",
      "description": "Available delivery dispatch methods"
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Transactions history logs"
    },
    "newsletter/{subscriberEmail}": {
      "schema": "Subscriber",
      "description": "Subscribed address registers"
    },
    "registered_users/{email}": {
      "description": "Registered user accounts. Document ID is email (lowercased).",
      "fields": {
        "name": "string",
        "email": "string",
        "phone": "string",
        "address": "string",
        "city": "string",
        "passwordHash": "string"
      }
    }
